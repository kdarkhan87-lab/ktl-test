rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: read/write only own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Results subcollection: only own
      match /results/{resultId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Leaderboard: any logged-in user can read; only own entry can be written
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Questions, tests, settings: read for all logged-in, write for admin only
    match /questions/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super-admin'];
    }
    match /tests/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super-admin'];
    }
    match /settings/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super-admin'];
    }
  }
}
